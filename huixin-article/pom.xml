            <artifactId>spring-cloud-starter-loadbalancer</artifactId>
        </dependency>
        <dependency>
            <groupId>com.huixin</groupId>
            <artifactId>huixin-common</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
